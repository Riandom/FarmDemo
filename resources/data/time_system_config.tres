[gd_resource type="Resource" script_class="TimeSystemConfig" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/time_system_config.gd" id="1_time_system_config"]

[resource]
script = ExtResource("1_time_system_config")
ke_duration_seconds = 30.0
days_per_solar_term = 7
