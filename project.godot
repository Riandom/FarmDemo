; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Farm Demo"
run/main_scene="res://scenes/app/main.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")

[autoload]

FarmManager="*res://scenes/systems/farm_manager.tscn"
ConfigManager="*res://scenes/systems/config_manager.tscn"
EventManager="*res://scenes/systems/event_manager.tscn"
FarmInteractionSystem="*res://scenes/systems/farm_interaction_system.tscn"
FarmRenderSystem="*res://scenes/systems/farm_render_system.tscn"
GameManager="*res://scenes/systems/game_manager.tscn"
EffectManager="*res://scenes/systems/effect_manager.tscn"
TimeManager="*res://scenes/systems/time_manager.tscn"
SaveManager="*res://scenes/systems/save_manager.tscn"
OrderManager="*res://scenes/systems/order_manager.tscn"
WorldAreaManager="*res://scenes/systems/world_area_manager.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

